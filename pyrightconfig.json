{
  "include": ["backend/api", "backend/ingestion"],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/*.pyc",
    "**/.venv",
    "**/dist"
  ],
  "pythonVersion": "3.12",
  "pythonPlatform": "Linux",
  "typeCheckingMode": "basic",
  "reportMissingImports": true,
  "reportMissingModuleSource": false,
  "venvPath": ".",
  "venv": ".venv"
}
