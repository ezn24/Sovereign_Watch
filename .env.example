# ============================================
# Sovereign Watch - Environment Configuration
# ============================================
# Copy this file to .env and customize values

# --- Location Center (All Services Use This) ---
# These coordinates define the monitoring region center
# Used by: adsb-poller, ais-poller, frontend map
CENTER_LAT=45.5152
CENTER_LON=-122.6784
COVERAGE_RADIUS_NM=150

# --- Tactical & System ---
# Interval for evicting stale aircraft arbitration entries (seconds)
ARBITRATION_CLEANUP_INTERVAL=30

# --- JS8Call Radio Terminal ---
# KiwiSDR source for headless JS8Call audio ingestion
KIWI_HOST=kiwisdr.example.com
KIWI_PORT=8073
KIWI_FREQ=14074
KIWI_MODE=usb
# Operator's Maidenhead locator (for distance/bearing)
MY_GRID=CN85

# --- Database ---
POSTGRES_PASSWORD=postgres

# --- AIS Poller---
AISSTREAM_API_KEY=your_key_here

# --- LiteLLM ---
# Default model for the Front End Analyst
LITELLM_MODEL=secure-core
#secure-core
# If running in docker composition, might be http://localai:8080 or http://ollama:11434
OPEN_API_BASE=http://host.docker.internal:11434
# API key is just needed for LiteLLM to work with Offline OpenAPI models
OPEN_API_KEY=not-needed
OPEN_API_MODEL=openai/llama3
OPEN_API_LABEL=Llama3 (Local)
#public-flash
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini/gemini-2.5-flash
GEMINI_LABEL=Gemini 2.5 Flash
# deep-reasoner
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=anthropic/claude-3-5-sonnet-20240620
ANTHROPIC_LABEL=Claude 3.5 Sonnet

# --- RF Pulse ---
# Default Polling Radius
RF_RB_RADIUS_MI=200
# RepeaterBook (ham repeaters)
REPEATERBOOK_API_TOKEN=your_token_here
RF_REPEATERBOOK_INTERVAL_H=6
# ARD (Amateur Repeater Directory - open source)
RF_ARD_INTERVAL_H=24
# NOAA NWR (Weather Band Radios)
RF_NOAA_INTERVAL_H=168
# RadioReference (Public safety trunked systems)
# Requires a RadioReference premium (licensed) account + developer app key
# Get your app key at: https://www.radioreference.com/apps/api/
RADIOREF_APP_KEY=your_app_key_here
RADIOREF_USERNAME=your_rr_username_here
RADIOREF_PASSWORD=your_rr_password_here

# --- Frontend ---
# Set to false to force MapLibre fallback even if a token is present
VITE_ENABLE_MAPBOX=true
# Mapbox: Get from https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here
# Toggle 3D terrain/elevation (may impact performance)
VITE_ENABLE_3D_TERRAIN=false

# --- CORS & Network ---
# Comma-separated list of allowed origins for the backend and radio bridge.
# When running on a server, add http://<SERVER_IP> here.
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
#JS8 Websocket Host
VITE_JS8_WS_URL=http://localhost
VITE_JS8_BASE_URL=http://localhost