{
  "mcpServers": {
    "graph-it-live": {
      "command": "bash",
      "args": [
        "-c",
        "node $HOME/.vscode/extensions/magic5644.graph-it-live-*/dist/mcpServer.mjs"
      ],
      "env": {
        "WORKSPACE_ROOT": ".",
        "EXCLUDE_NODE_MODULES": "true",
        "MAX_DEPTH": "50"
      }
    },
    "pyright": {
      "command": "bash",
      "args": ["./tools/mcp-language-server/run-pyright.sh"],
      "env": {}
    },
    "tsserver": {
      "command": "bash",
      "args": ["./tools/mcp-language-server/run-tsserver.sh"],
      "env": {}
    }
  }
}
