{
  "mcpServers": {
    "graph-it-live": {
      "command": "bash",
      "args": [
        "-c",
        "node $HOME/.vscode/extensions/magic5644.graph-it-live-*/dist/mcpServer.mjs"
      ],
      "env": {
        "WORKSPACE_ROOT": ".",
        "EXCLUDE_NODE_MODULES": "true",
        "MAX_DEPTH": "50"
      }
    },
    "pyright": {
      "command": "./tools/bin/mcp-language-server",
      "args": ["-workspace", "/home/user/Sovereign_Watch", "-lsp", "pyright-langserver", "--", "--stdio"],
      "env": {}
    },
    "tsserver": {
      "command": "./tools/bin/mcp-language-server",
      "args": ["-workspace", "/home/user/Sovereign_Watch", "-lsp", "typescript-language-server", "--", "--stdio"],
      "env": {}
    }
  }
}
